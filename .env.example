APP_NAME="Open Courts"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://lvh.me:8000

# Central (apex) domain. Clubs live on subdomains, e.g. http://smashclub.lvh.me:8000.
# lvh.me (and *.lvh.me) resolve to 127.0.0.1, so club subdomains work locally AND the
# session cookie is shared across them (unlike *.localhost). Tests pin this to localhost.
CENTRAL_DOMAIN=lvh.me

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Runtime database is PostgreSQL; the schema stays DB-neutral (Eloquent only).
# Host dev connects to the dockerised Postgres via the published port; the container
# uses the service name (see docker-compose.yml). The test suite runs on in-memory
# SQLite (phpunit.xml) to prove the schema is portable.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=open_tennis
DB_USERNAME=open_tennis
DB_PASSWORD=secret

# --- Docker published ports (host side) ---
APP_HOST_PORT=8080
DB_HOST_PORT=5432
REDIS_HOST_PORT=6379
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_PORT=1025

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Cookie domain = the central domain, so the session is shared across club subdomains
# (e.g. lvh.me + smashclub.lvh.me). In production set this to your apex domain.
SESSION_DOMAIN=lvh.me

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
